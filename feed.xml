---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <description>{{ site.description | xml_escape }}</description>
    <language>{{ site.lang | default: "ko" }}</language>
    <copyright>Copyright {{ site.time | date: "%Y" }} {{ site.author.name | xml_escape }}</copyright>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <ttl>360</ttl>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
    {% if site.author.email and site.author.email != "" %}
    <managingEditor>{{ site.author.email }} ({{ site.author.name }})</managingEditor>
    <webMaster>{{ site.author.email }} ({{ site.author.name }})</webMaster>
    {% endif %}
    <image>
      <url>{{ site.url }}{{ site.baseurl }}/assets/images/logo.png</url>
      <title>{{ site.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}/</link>
      <width>144</width>
      <height>144</height>
    </image>
    {% for post in site.posts limit: 50 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}{{ post.url }}</link>
      <dc:creator>{{ site.author.name | xml_escape }}</dc:creator>
      <description>{{ post.excerpt | strip_html | strip_newlines | xml_escape | truncate: 500 }}</description>
      <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <guid isPermaLink="true">{{ site.url }}{{ site.baseurl }}{{ post.url }}</guid>
      {% for category in post.categories %}
      <category>{{ category | xml_escape }}</category>
      {% endfor %}
      {% for tag in post.tags %}
      <category>{{ tag | xml_escape }}</category>
      {% endfor %}
      {% if post.image %}
      {%- comment -%}
        Swap .svg → .png/_og.png for feed media: most RSS readers (Feedly,
        Inoreader, Apple News) cannot render inline SVG previews. Mirrors the
        logic in _includes/head.html and _plugins/svg_to_png_og.rb so feed
        media:content stays in lockstep with og:image.
      {%- endcomment -%}
      {% assign feed_image = post.image %}
      {% if feed_image contains '.svg' %}
        {% assign feed_image_png = feed_image | replace: '.svg', '.png' %}
        {% assign feed_image_og_png = feed_image | replace: '.svg', '_og.png' %}
        {% assign feed_png_file = site.static_files | where: 'path', feed_image_png | first %}
        {% assign feed_og_png_file = site.static_files | where: 'path', feed_image_og_png | first %}
        {% if feed_png_file %}{% assign feed_image = feed_image_png %}{% elsif feed_og_png_file %}{% assign feed_image = feed_image_og_png %}{% endif %}
      {% endif %}
      {% assign feed_image_mime = 'image/png' %}
      {% if feed_image contains '.jpg' or feed_image contains '.jpeg' %}{% assign feed_image_mime = 'image/jpeg' %}{% endif %}
      {% if feed_image contains '.webp' %}{% assign feed_image_mime = 'image/webp' %}{% endif %}
      {% if feed_image contains '.svg' %}{% assign feed_image_mime = 'image/svg+xml' %}{% endif %}
      <media:content url="{{ site.url }}{{ site.baseurl }}{{ feed_image }}" medium="image" type="{{ feed_image_mime }}" width="1200" height="630"/>
      <media:thumbnail url="{{ site.url }}{{ site.baseurl }}{{ feed_image }}" width="1200" height="630"/>
      {% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
