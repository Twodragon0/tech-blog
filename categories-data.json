---
layout: null
permalink: /categories-data.json
sitemap: false
---
{%- comment -%}
  Categories lazy-render data endpoint. Mirror of /tags-data.json.

  Per-post payload keys (terse to keep transfer small):
    t  : title
    u  : URL (relative)
    d  : human date "YYYY. MM. DD"
    x  : ISO 8601 datetime
    c  : primary category badge label
    cs : space-joined data-category string (matches the inline post-card)
    tags : up to 3 tag labels (extra count rendered as "+N")
    tn : total tag count (so JS can render "+N more" without sending them)
    ex : excerpt (160 char truncated)
    img: front-matter image path (svg/png as authored)
    ip : 1 if post.image rewrites to *_og.png at build (i.e. PNG companion exists),
         0 if it is still .svg (no _og.png on disk)
    ia : 1 if *_og.avif exists
    iw : 1 if *_og.webp exists
    ica: 1 if *_card.avif exists (525w responsive)
    icw: 1 if *_card.webp exists
{%- endcomment -%}
{
{%- assign cats = site.category_list -%}
{%- for cat in cats -%}
{%- assign cat_name_lower = cat.name | downcase -%}
{%- assign cat_posts = "" | split: "" -%}
{%- for post in site.posts -%}
  {%- assign post_matched = false -%}
  {%- if post.category and post.category != "" -%}
    {%- assign post_cat_lower = post.category | downcase | strip -%}
    {%- if post_cat_lower == cat_name_lower -%}{%- assign post_matched = true -%}{%- endif -%}
  {%- endif -%}
  {%- unless post_matched -%}
    {%- if post.categories -%}
      {%- assign categories_size = post.categories | size -%}
      {%- if categories_size > 0 -%}
        {%- for post_cat in post.categories -%}
          {%- assign post_cat_lower = post_cat | downcase | strip -%}
          {%- if post_cat_lower == cat_name_lower -%}
            {%- assign post_matched = true -%}{%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign post_cat_lower = post.categories | downcase | strip -%}
        {%- if post_cat_lower == cat_name_lower -%}{%- assign post_matched = true -%}{%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endunless -%}
  {%- unless post_matched -%}
    {%- assign classifier = post.title | append: ' ' | append: post.excerpt | downcase -%}
    {%- if post.tags -%}{%- assign classifier = classifier | append: ' ' | append: post.tags | downcase -%}{%- endif -%}
    {%- if cat_name_lower == 'devops' -%}
      {%- if classifier contains 'devops' or classifier contains 'ci/cd' or classifier contains 'cicd' or classifier contains 'pipeline' or classifier contains 'github actions' or classifier contains 'automation' or classifier contains 'terraform' or classifier contains 'ansible' -%}{%- assign post_matched = true -%}{%- endif -%}
    {%- elsif cat_name_lower == 'kubernetes' -%}
      {%- if classifier contains 'kubernetes' or classifier contains 'k8s' or classifier contains 'eks' -%}{%- assign post_matched = true -%}{%- endif -%}
    {%- elsif cat_name_lower == 'blockchain' -%}
      {%- if classifier contains 'blockchain' or classifier contains 'bitcoin' or classifier contains 'crypto' or classifier contains 'ethereum' or classifier contains 'web3' -%}{%- assign post_matched = true -%}{%- endif -%}
    {%- endif -%}
  {%- endunless -%}
  {%- if post_matched -%}{%- assign cat_posts = cat_posts | push: post -%}{%- endif -%}
{%- endfor -%}
{%- if cat_posts.size == 0 -%}{%- continue -%}{%- endif -%}
"{{ cat.name }}": {
"name": {{ cat.name | jsonify }},
"title": {{ cat.title | jsonify }},
"posts": [
{%- for post in cat_posts -%}
{%- assign post_cats_str = "" -%}
{%- if post.category and post.category != "" -%}{%- assign post_cats_str = post.category | downcase | strip -%}{%- endif -%}
{%- if post.categories -%}
  {%- for c in post.categories -%}
    {%- assign c_lower = c | downcase | strip -%}
    {%- unless post_cats_str contains c_lower -%}
      {%- if post_cats_str != "" -%}{%- assign post_cats_str = post_cats_str | append: " " | append: c_lower -%}
      {%- else -%}{%- assign post_cats_str = c_lower -%}{%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}
{%- assign primary_cat = "" -%}
{%- if post.category and post.category != "" -%}{%- assign primary_cat = post.category -%}
{%- elsif post.categories.first -%}{%- assign primary_cat = post.categories.first -%}{%- endif -%}
{%- assign img_path = post.image | default: "" -%}
{%- assign img_png_path = img_path | replace: '.svg', '_og.png' -%}
{%- assign img_avif_path = img_path | replace: '.svg', '_og.avif' | replace: '.png', '_og.avif' -%}
{%- assign img_webp_path = img_path | replace: '.svg', '_og.webp' | replace: '.png', '_og.webp' -%}
{%- assign img_card_avif_path = img_path | replace: '.svg', '_card.avif' | replace: '.png', '_card.avif' -%}
{%- assign img_card_webp_path = img_path | replace: '.svg', '_card.webp' | replace: '.png', '_card.webp' -%}
{%- assign has_png = site.static_files | where: 'path', img_png_path | first -%}
{%- assign has_avif = site.static_files | where: 'path', img_avif_path | first -%}
{%- assign has_webp = site.static_files | where: 'path', img_webp_path | first -%}
{%- assign has_card_avif = site.static_files | where: 'path', img_card_avif_path | first -%}
{%- assign has_card_webp = site.static_files | where: 'path', img_card_webp_path | first -%}
{%- assign tag_count = post.tags | size -%}
{%- assign first_tags = post.tags | slice: 0, 3 -%}
{%- assign excerpt_clean = post.excerpt | strip_html | strip_newlines | truncate: 160 -%}
{
"t": {{ post.title | jsonify }},
"u": {{ post.url | relative_url | jsonify }},
"d": {{ post.date | date: "%Y. %m. %d" | jsonify }},
"x": {{ post.date | date_to_xmlschema | jsonify }},
"c": {{ primary_cat | jsonify }},
"cs": {{ post_cats_str | jsonify }},
"tags": [{%- for t in first_tags -%}{{ t | jsonify }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
"tn": {{ tag_count }},
"ex": {{ excerpt_clean | jsonify }},
"img": {{ img_path | relative_url | jsonify }},
"ip": {%- if has_png -%}1{%- else -%}0{%- endif -%},
"ia": {%- if has_avif -%}1{%- else -%}0{%- endif -%},
"iw": {%- if has_webp -%}1{%- else -%}0{%- endif -%},
"ica": {%- if has_card_avif -%}1{%- else -%}0{%- endif -%},
"icw": {%- if has_card_webp -%}1{%- else -%}0{%- endif -%}
}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
}
