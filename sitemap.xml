---
layout: null
sitemap:
  exclude: 'yes'
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
        http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Static Pages (HTML only, exclude CSS/JS/XML/feeds) -->
  {% for page in site.pages %}
    {% assign ext = page.url | split: '.' | last %}
    {% unless page.sitemap.exclude == 'yes'
      or page.url == '/feed.xml'
      or page.url == '/sitemap.xml'
      or page.url == '/robots.txt'
      or page.url == '/llms.txt'
      or page.url == '/llms-full.txt'
      or page.url == '/'
      or page.url == '/404.html'
      or ext == 'css'
      or ext == 'js'
      or ext == 'json'
      or ext == 'xml'
      or ext == 'txt'
      or ext == 'ico'
      or ext == 'png'
      or ext == 'svg'
      or ext == 'map'
      or page.url contains '.css.map'
      or page.url contains '.js.map'
    %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
      <lastmod>{{ page.last_modified_at | default: page.date | default: site.time | date_to_xmlschema }}</lastmod>
      <changefreq>{% if page.url contains '/about' or page.url contains '/support' %}monthly{% else %}weekly{% endif %}</changefreq>
      <priority>{% if page.url contains '/about' %}0.8{% elsif page.url contains '/categories' or page.url contains '/tags' or page.url contains '/archive' %}0.7{% elsif page.url contains '/certifications' %}0.7{% else %}0.6{% endif %}</priority>
    </url>
    {% endunless %}
  {% endfor %}

  <!-- Blog Posts with Image Sitemap -->
  {% for post in site.posts %}
    {% unless post.sitemap.exclude == 'yes' %}
    {% assign post_date = post.date | date: '%s' | plus: 0 %}
    {% assign current_date = site.time | date: '%s' | plus: 0 %}
    {% assign days_since = current_date | minus: post_date | divided_by: 86400 %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
      <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
      <changefreq>{% if days_since < 7 %}daily{% elsif days_since < 30 %}weekly{% elsif days_since < 180 %}monthly{% else %}yearly{% endif %}</changefreq>
      <priority>{% if days_since < 7 %}0.9{% elsif days_since < 30 %}0.8{% elsif days_since < 180 %}0.7{% else %}0.5{% endif %}</priority>
      {% if post.image %}
      {%- comment -%}
        Image sitemap should point to a raster source so Google Image Search
        can index it; SVG covers don't appear in image search reliably. Swap
        to the matching .png/_og.png variant when one is generated by
        scripts/generate_missing_og_pngs.py. Falls back to the original path
        when no PNG variant exists.
      {%- endcomment -%}
      {% assign sm_image = post.image %}
      {% if sm_image contains '.svg' %}
        {% assign sm_image_png = sm_image | replace: '.svg', '.png' %}
        {% assign sm_image_og_png = sm_image | replace: '.svg', '_og.png' %}
        {% assign sm_png_file = site.static_files | where: 'path', sm_image_png | first %}
        {% assign sm_og_png_file = site.static_files | where: 'path', sm_image_og_png | first %}
        {% if sm_png_file %}{% assign sm_image = sm_image_png %}{% elsif sm_og_png_file %}{% assign sm_image = sm_image_og_png %}{% endif %}
      {% endif %}
      <image:image>
        <image:loc>{{ site.url }}{{ site.baseurl }}{{ sm_image }}</image:loc>
        <image:title>{{ post.title | xml_escape }}</image:title>
        <image:caption>{{ post.image_alt | default: post.excerpt | strip_html | strip_newlines | truncate: 160 | xml_escape }}</image:caption>
      </image:image>
      {% endif %}
    </url>
    {% endunless %}
  {% endfor %}

</urlset>
