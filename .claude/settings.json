{
  "_meta": {
    "comment": "Project-scoped Claude Code settings — committed, shared across the team.",
    "auth_note": "Auth precedence (subscription vs API key) is resolved by Claude Code CLI; the previous settings.json had documentation-only fields that the CLI ignored. Per-developer overrides go in .claude/settings.local.json (gitignored).",
    "lastReview": "2026-05-06"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-svg.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/canonical-url-gate.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
