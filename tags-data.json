---
layout: null
permalink: /tags-data.json
sitemap: false
---
{%- assign all_tags = site.posts | map: "tags" | flatten | compact | uniq | sort_natural -%}
{
{%- assign emitted = 0 -%}
{%- for tag in all_tags -%}
{%- assign tag_str = tag | append: "" -%}
{%- assign tag_posts = site.posts | where_exp: "post", "post.tags contains tag" -%}
{%- if tag_posts.size == 0 -%}{%- continue -%}{%- endif -%}
{%- if emitted > 0 -%},{%- endif -%}
{%- assign emitted = emitted | plus: 1 -%}
{%- assign related_candidates = "" | split: "" -%}
{%- for post in tag_posts -%}
{%- for ptag in post.tags -%}
{%- assign ptag_str = ptag | append: "" -%}
{%- unless ptag_str == tag_str -%}
{%- assign related_candidates = related_candidates | push: ptag_str -%}
{%- endunless -%}
{%- endfor -%}
{%- endfor -%}
{%- assign related_tags = related_candidates | uniq | slice: 0, 5 -%}
"{{ tag_str | slugify }}": {
"name": {{ tag_str | jsonify }},
"related": [{%- for r in related_tags -%}{{ r | jsonify }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
"posts": [{%- for post in tag_posts -%}{
"t": {{ post.title | jsonify }},
"u": {{ post.url | relative_url | jsonify }},
"d": {{ post.date | date: "%Y. %m. %d" | jsonify }},
"x": {{ post.date | date_to_xmlschema | jsonify }},
"c": {%- if post.category -%}{{ post.category | jsonify }}{%- elsif post.categories.first -%}{{ post.categories.first | jsonify }}{%- else -%}""{%- endif -%}
}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
}
{%- endfor -%}
}
